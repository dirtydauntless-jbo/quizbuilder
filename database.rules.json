      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('config/masterAdmins').child(auth.uid).val() === true)",
        ".write": "auth != null && auth.uid === $uid && newData.isNumber() && newData.val() <= now && newData.val() >= now - 60000 && (!data.exists() || newData.val() > data.val() + 8000)"
      }
    },
