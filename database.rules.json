        "completed": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000" },
        "taken":     { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000" },
        "avgSpq":    { ".validate": "newData.val() === null || (newData.isNumber() && newData.val() >= 0)" },
        "updatedAt": { ".validate": "newData.isNumber()" },
        "$other":    { ".validate": false }
      }
